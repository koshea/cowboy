---
source: crates/cowboy-cli/src/agent/tools.rs
expression: defs
---
[
  {
    "description": "Run a shell command inside the container and observe its output. Use this for builds, tests, git, and cowboy CLIs like `cowboy patch`. For reading or editing files, prefer the `read`/`edit`/`write` tools.",
    "name": "shell",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `shell` tool.",
      "properties": {
        "command": {
          "description": "The shell command to run inside the container (executed with `sh -lc`).",
          "type": "string"
        },
        "cwd": {
          "default": null,
          "description": "Optional working directory (defaults to the container workdir).",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "command"
      ],
      "title": "ShellArgs",
      "type": "object"
    }
  },
  {
    "description": "Read a file from the workspace with line numbers. Prefer this over `cat`/`sed` — the line numbers help you make precise edits.",
    "name": "read",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `read` tool.",
      "properties": {
        "limit": {
          "default": null,
          "description": "Maximum number of lines to return.",
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "offset": {
          "default": null,
          "description": "1-based line to start at (default 1).",
          "format": "uint",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "path": {
          "description": "Path to the file (workspace-relative, e.g. `src/main.rs`).",
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "title": "ReadArgs",
      "type": "object"
    }
  },
  {
    "description": "Replace an exact span of text in a file. `old` must match exactly and be unique unless `replace_all` is set. Prefer this over `sed`/heredocs for edits — it is precise and fails loudly if `old` is missing or ambiguous.",
    "name": "edit",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `edit` tool.",
      "properties": {
        "new": {
          "description": "Replacement text.",
          "type": "string"
        },
        "old": {
          "description": "Exact text to replace. Must match a unique span unless `replace_all`.",
          "type": "string"
        },
        "path": {
          "description": "Path to the file to edit (workspace-relative).",
          "type": "string"
        },
        "replace_all": {
          "default": false,
          "description": "Replace every occurrence instead of requiring a unique match.",
          "type": "boolean"
        }
      },
      "required": [
        "path",
        "old",
        "new"
      ],
      "title": "EditArgs",
      "type": "object"
    }
  },
  {
    "description": "Create a new file or overwrite an existing one with the given content. Parent directories are created. Prefer this over `echo >`/heredocs.",
    "name": "write",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `write` tool.",
      "properties": {
        "content": {
          "description": "Full file contents (overwrites any existing file).",
          "type": "string"
        },
        "path": {
          "description": "Path to write (workspace-relative). Parent directories are created.",
          "type": "string"
        }
      },
      "required": [
        "path",
        "content"
      ],
      "title": "WriteArgs",
      "type": "object"
    }
  },
  {
    "description": "Your durable cross-session memory (stored on the host, not in the repo). `save` a concise fact or user preference worth remembering next time (scope \"project\" by default, or \"global\" across projects); `recall` a full entry by name; `list` the index; `delete` one. The index of saved memories is shown to you at the start of each session. Do NOT use this for project conventions that belong in the repo — put those in AGENTS.md.",
    "name": "memory",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `memory` tool.",
      "properties": {
        "action": {
          "description": "What to do: \"save\", \"recall\", \"list\", or \"delete\".",
          "type": "string"
        },
        "content": {
          "default": null,
          "description": "For `save`: the full memory body to store.",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "default": null,
          "description": "For `recall`/`delete`: the memory name (slug) shown in the index.",
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "default": null,
          "description": "For `save`: \"project\" (default) or \"global\".",
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "default": null,
          "description": "For `save`: a one-line title (becomes the index description and slug).",
          "type": [
            "string",
            "null"
          ]
        },
        "type": {
          "default": null,
          "description": "For `save`: a free-form category, e.g. \"preference\" or \"fact\".",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "action"
      ],
      "title": "MemoryArgs",
      "type": "object"
    }
  },
  {
    "description": "Maintain a short, visible checklist for a multi-step task. Pass the full ordered list of `steps` (each with a `status` of \"pending\", \"in_progress\", or \"done\"); the list REPLACES the previous plan. Create a plan before starting non-trivial work, mark exactly one step \"in_progress\" at a time, and update statuses as you go. Skip it for trivial one-step tasks.",
    "name": "plan",
    "parameters": {
      "$defs": {
        "PlanStep": {
          "description": "One step in the agent's working plan.",
          "properties": {
            "status": {
              "default": null,
              "description": "Status: \"pending\" (default), \"in_progress\", or \"done\".",
              "type": [
                "string",
                "null"
              ]
            },
            "step": {
              "description": "A short description of the step.",
              "type": "string"
            }
          },
          "required": [
            "step"
          ],
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `plan` tool. The whole list is replaced on each call.",
      "properties": {
        "steps": {
          "description": "The full, ordered list of steps; replaces the current plan.",
          "items": {
            "$ref": "#/$defs/PlanStep"
          },
          "type": "array"
        }
      },
      "required": [
        "steps"
      ],
      "title": "PlanArgs",
      "type": "object"
    }
  },
  {
    "description": "Publish a durable, typed output others (or a later session) can consume — a contract, summary, test result, patch, notes, etc. `publish` with a workspace `path` or inline `content`, a `kind`, a `title`, and a one-line `summary`; `list` shows this session's artifacts. Prefer publishing a concrete artifact (e.g. an API/schema contract) over describing it only in prose.",
    "name": "artifact",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `artifact` tool.",
      "properties": {
        "action": {
          "description": "\"publish\" (store an output) or \"list\" (show this session's artifacts).",
          "type": "string"
        },
        "content": {
          "default": null,
          "description": "For `publish`: inline content instead of (or in addition to) `path`.",
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "default": null,
          "description": "For `publish`: kind — contract|summary|patch|diff|test_result|notes|review|other.",
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "default": null,
          "description": "For `publish`: a workspace-relative file to publish (e.g. `docs/api.md`).",
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "default": null,
          "description": "For `publish`: a one-line summary of what the artifact is/contains.",
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "default": null,
          "description": "For `publish`: a short human title (defaults to the file name).",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "action"
      ],
      "title": "ArtifactArgs",
      "type": "object"
    }
  },
  {
    "description": "Write a structured handoff summary for whoever continues this work (a teammate, a later session, or a Ranch coordinator): goal, status, changed files, decisions, contracts, validation, risks, next steps. Call this at the end of a substantial task, just before `final`.",
    "name": "handoff",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `handoff` tool — a structured end-of-session summary that\nthe next worker (or a Ranch coordinator) can rely on.",
      "properties": {
        "changed_files": {
          "default": null,
          "description": "Files created/changed (and how), if any.",
          "type": [
            "string",
            "null"
          ]
        },
        "contracts": {
          "default": null,
          "description": "Interfaces/contracts introduced or changed (point at published artifacts).",
          "type": [
            "string",
            "null"
          ]
        },
        "decisions": {
          "default": null,
          "description": "Important decisions made and why.",
          "type": [
            "string",
            "null"
          ]
        },
        "goal": {
          "description": "What this session set out to do.",
          "type": "string"
        },
        "next_steps": {
          "default": null,
          "description": "Recommended next steps for whoever picks this up.",
          "type": [
            "string",
            "null"
          ]
        },
        "risks": {
          "default": null,
          "description": "Known risks or gaps.",
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "description": "Outcome: complete | partial | blocked | failed.",
          "type": "string"
        },
        "validation": {
          "default": null,
          "description": "How the work was validated (tests/builds run and their result).",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "goal",
        "status"
      ],
      "title": "HandoffArgs",
      "type": "object"
    }
  },
  {
    "description": "Ask the user to make a decision and record it durably (question, options, chosen answer, rationale) so the rationale survives and downstream work can depend on it. Use for choices that shape the work (data model, protocol, API shape), not routine questions.",
    "name": "decision",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `decision` tool — ask the user to decide and record it.",
      "properties": {
        "options": {
          "default": null,
          "description": "Optional choices to present.",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "question": {
          "description": "The decision to make (asked to the user).",
          "type": "string"
        },
        "rationale": {
          "default": null,
          "description": "Optional rationale/context to record alongside the decision.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "question"
      ],
      "title": "DecisionArgs",
      "type": "object"
    }
  },
  {
    "description": "Declare that you cannot proceed and need an external input (a decision, a dependency's artifact, access). Give a clear `reason` and optionally `waiting_on`. Use `unblock` once you can continue. This surfaces the session as blocked to the user / Ranch coordinator.",
    "name": "blocked",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `blocked` tool.",
      "properties": {
        "reason": {
          "description": "Why you cannot proceed (e.g. \"need the API contract from the schema work\").",
          "type": "string"
        },
        "waiting_on": {
          "default": null,
          "description": "Optional: what you're waiting on (artifact names, workstream ids, a person).",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ]
        }
      },
      "required": [
        "reason"
      ],
      "title": "BlockedArgs",
      "type": "object"
    }
  },
  {
    "description": "Clear a previously-declared blocked state once you can proceed again.",
    "name": "unblock",
    "parameters": {
      "properties": {},
      "type": "object"
    }
  },
  {
    "description": "When running a Ranch workstream and the plan itself looks wrong (a workstream is missing, unnecessary, or misscoped), DO NOT edit the ranch plan — file a proposal here. It records a pending change the user reviews and approves/rejects; the plan only changes on approval. Use `change`: add_workstream (with workstream_id/title/goal/depends_on), remove_workstream (workstream_id), or note (a concern). Outside a ranch this is unavailable.",
    "name": "propose_scope_change",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `propose_scope_change` tool.",
      "properties": {
        "change": {
          "description": "The change: \"add_workstream\", \"remove_workstream\", or \"note\" (a concern with\nno concrete edit).",
          "type": "string"
        },
        "depends_on": {
          "default": null,
          "description": "For add_workstream: ids it depends on.",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "goal": {
          "default": null,
          "description": "For add_workstream: the goal/description.",
          "type": [
            "string",
            "null"
          ]
        },
        "rationale": {
          "default": null,
          "description": "Why the plan should change (what you learned that the plan didn't anticipate).",
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "description": "One-line summary of the proposed change.",
          "type": "string"
        },
        "title": {
          "default": null,
          "description": "For add_workstream: a short title.",
          "type": [
            "string",
            "null"
          ]
        },
        "workstream_id": {
          "default": null,
          "description": "For add/remove: the workstream id.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "summary",
        "change"
      ],
      "title": "ProposeScopeChangeArgs",
      "type": "object"
    }
  },
  {
    "description": "Propose a multi-workstream Ranch Plan: decompose a large goal into independent, parallelizable workstreams wired by `depends_on` into a DAG, each with a goal, expected artifacts, and acceptance criteria. Use ONLY when explicitly asked to plan/decompose a ranch — it writes a draft ranch.yaml for the user to review and does NOT start any work or edit code. Call it once with the full decomposition.",
    "name": "propose_ranch",
    "parameters": {
      "$defs": {
        "RanchWorkstreamArg": {
          "description": "One workstream in a proposed Ranch Plan (see [`ProposeRanchArgs`]).",
          "properties": {
            "acceptance": {
              "default": [],
              "description": "Human-readable acceptance criteria.",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "depends_on": {
              "default": [],
              "description": "Ids of workstreams that must finish before this one starts (forms a DAG).",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "expected_artifacts": {
              "default": [],
              "description": "Artifacts this workstream is expected to publish (names, not paths).",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "goal": {
              "description": "What this workstream should accomplish.",
              "type": "string"
            },
            "id": {
              "description": "Short, unique slug id (e.g. `schema`, `api`).",
              "type": "string"
            },
            "title": {
              "default": null,
              "description": "Display title (defaults to the id).",
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "id",
            "goal"
          ],
          "type": "object"
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `propose_ranch` tool: a full multi-workstream decomposition.",
      "properties": {
        "goal": {
          "description": "The overall goal the ranch achieves.",
          "type": "string"
        },
        "title": {
          "description": "Title for the ranch plan.",
          "type": "string"
        },
        "workstreams": {
          "description": "The workstreams, with `depends_on` wiring them into a dependency DAG.",
          "items": {
            "$ref": "#/$defs/RanchWorkstreamArg"
          },
          "type": "array"
        }
      },
      "required": [
        "title",
        "goal",
        "workstreams"
      ],
      "title": "ProposeRanchArgs",
      "type": "object"
    }
  },
  {
    "description": "Finish the task. Provide a summary of what changed, what was validated, and any remaining risks or follow-up work.",
    "name": "final",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `final` tool.",
      "properties": {
        "message": {
          "description": "A summary of what changed, what was validated, and any follow-ups.",
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "title": "FinalArgs",
      "type": "object"
    }
  },
  {
    "description": "Ask the user a question when you are genuinely blocked and cannot proceed without their input. Provide `options` (2–4 short choices) when the answer is a clear pick — the user gets a selectable list and can still type their own answer.",
    "name": "ask_user",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `ask_user` tool.",
      "properties": {
        "options": {
          "default": null,
          "description": "Optional suggested answers to present as a pick-list. The user may still\ntype a free-form answer (\"other\").",
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "question": {
          "description": "A question for the user when the agent is genuinely blocked.",
          "type": "string"
        }
      },
      "required": [
        "question"
      ],
      "title": "AskUserArgs",
      "type": "object"
    }
  },
  {
    "description": "Delegate a focused, independent sub-task to a worker that shares this workspace/container. Describe the work by `category` (the kind: tests, exploration, frontend, review, …) and `effort` (tiny/small/medium/large/deep) — Cowboy routes it to the right model from the user's crew roster. Do NOT pick a model. Optionally set `agent` to adopt a named specialist definition from `.claude/agents/`/`.cowboy/agents/` (e.g. \"security-reviewer\"; discover with `cowboy agents list`). Include a `reason` and the `expected_artifact`. Returns the worker's final summary. Prefer small, well-scoped tasks; emit several calls in one message to run them in parallel.",
    "name": "subagent",
    "parameters": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Arguments for the `subagent` tool.",
      "properties": {
        "agent": {
          "default": null,
          "description": "Optional: a named agent definition to adopt (from `.claude/agents/` or\n`.cowboy/agents/`, e.g. \"security-reviewer\"). Its instructions are\nprepended so the worker takes on that persona. Discover names with\n`cowboy agents list`. (The crew still picks the model from category/effort.)",
          "type": [
            "string",
            "null"
          ]
        },
        "category": {
          "default": null,
          "description": "The KIND of work, so Cowboy routes it to the right crew model. One of:\ngeneral, exploration, backend, frontend, tests, review, docs, debugging,\nrefactor, e2e. Defaults to `general`. Do NOT name a model — routing is the\nuser's crew roster.",
          "type": [
            "string",
            "null"
          ]
        },
        "context": {
          "default": null,
          "description": "Optional extra context to prepend (the subagent starts with a fresh\nconversation, so include anything it needs to know).",
          "type": [
            "string",
            "null"
          ]
        },
        "effort": {
          "default": null,
          "description": "How hard the task is: tiny, small, medium, large, or deep. Defaults to\n`medium`. Used with `category` to pick the model.",
          "type": [
            "string",
            "null"
          ]
        },
        "expected_artifact": {
          "default": null,
          "description": "The concrete artifact you expect back (e.g. \"changed test files + summary\").",
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "default": null,
          "description": "Why you're delegating this (one line) — recorded with the routing decision.",
          "type": [
            "string",
            "null"
          ]
        },
        "task": {
          "description": "A focused, self-contained task for the subagent to complete.",
          "type": "string"
        }
      },
      "required": [
        "task"
      ],
      "title": "SubagentArgs",
      "type": "object"
    }
  }
]
