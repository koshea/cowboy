---
source: crates/cowboy-cli/src/agent/tools.rs
expression: defs
---
[
  {
    "description": "Run a shell command inside the container and observe its output. Use this for builds, tests, git, and cowboy CLIs like `cowboy patch`. For reading or editing files, prefer the `read`/`edit`/`write` tools.",
    "name": "shell",
    "parameters": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "description": "Arguments for the `shell` tool.",
      "properties": {
        "command": {
          "description": "The shell command to run inside the container (executed with `sh -lc`).",
          "type": "string"
        },
        "cwd": {
          "default": null,
          "description": "Optional working directory (defaults to the container workdir).",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "command"
      ],
      "title": "ShellArgs",
      "type": "object"
    }
  },
  {
    "description": "Read a file from the workspace with line numbers. Prefer this over `cat`/`sed` — the line numbers help you make precise edits.",
    "name": "read",
    "parameters": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "description": "Arguments for the `read` tool.",
      "properties": {
        "limit": {
          "default": null,
          "description": "Maximum number of lines to return.",
          "format": "uint",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "offset": {
          "default": null,
          "description": "1-based line to start at (default 1).",
          "format": "uint",
          "minimum": 0.0,
          "type": [
            "integer",
            "null"
          ]
        },
        "path": {
          "description": "Path to the file (workspace-relative, e.g. `src/main.rs`).",
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "title": "ReadArgs",
      "type": "object"
    }
  },
  {
    "description": "Replace an exact span of text in a file. `old` must match exactly and be unique unless `replace_all` is set. Prefer this over `sed`/heredocs for edits — it is precise and fails loudly if `old` is missing or ambiguous.",
    "name": "edit",
    "parameters": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "description": "Arguments for the `edit` tool.",
      "properties": {
        "new": {
          "description": "Replacement text.",
          "type": "string"
        },
        "old": {
          "description": "Exact text to replace. Must match a unique span unless `replace_all`.",
          "type": "string"
        },
        "path": {
          "description": "Path to the file to edit (workspace-relative).",
          "type": "string"
        },
        "replace_all": {
          "default": false,
          "description": "Replace every occurrence instead of requiring a unique match.",
          "type": "boolean"
        }
      },
      "required": [
        "new",
        "old",
        "path"
      ],
      "title": "EditArgs",
      "type": "object"
    }
  },
  {
    "description": "Create a new file or overwrite an existing one with the given content. Parent directories are created. Prefer this over `echo >`/heredocs.",
    "name": "write",
    "parameters": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "description": "Arguments for the `write` tool.",
      "properties": {
        "content": {
          "description": "Full file contents (overwrites any existing file).",
          "type": "string"
        },
        "path": {
          "description": "Path to write (workspace-relative). Parent directories are created.",
          "type": "string"
        }
      },
      "required": [
        "content",
        "path"
      ],
      "title": "WriteArgs",
      "type": "object"
    }
  },
  {
    "description": "Finish the task. Provide a summary of what changed, what was validated, and any remaining risks or follow-up work.",
    "name": "final",
    "parameters": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "description": "Arguments for the `final` tool.",
      "properties": {
        "message": {
          "description": "A summary of what changed, what was validated, and any follow-ups.",
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "title": "FinalArgs",
      "type": "object"
    }
  },
  {
    "description": "Ask the user a question when you are genuinely blocked and cannot proceed without their input.",
    "name": "ask_user",
    "parameters": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "description": "Arguments for the `ask_user` tool.",
      "properties": {
        "question": {
          "description": "A question for the user when the agent is genuinely blocked.",
          "type": "string"
        }
      },
      "required": [
        "question"
      ],
      "title": "AskUserArgs",
      "type": "object"
    }
  },
  {
    "description": "Delegate a large, independent sub-task to a fresh subagent that shares this workspace/container. Returns the subagent's final summary. Use for focused work you want handled with its own context.",
    "name": "subagent",
    "parameters": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "description": "Arguments for the `subagent` tool.",
      "properties": {
        "context": {
          "default": null,
          "description": "Optional extra context to prepend (the subagent starts with a fresh conversation, so include anything it needs to know).",
          "type": [
            "string",
            "null"
          ]
        },
        "task": {
          "description": "A focused, self-contained task for the subagent to complete.",
          "type": "string"
        }
      },
      "required": [
        "task"
      ],
      "title": "SubagentArgs",
      "type": "object"
    }
  }
]
