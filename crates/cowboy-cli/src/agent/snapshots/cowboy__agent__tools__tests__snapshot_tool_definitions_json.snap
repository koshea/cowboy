---
source: crates/cowboy-cli/src/agent/tools.rs
expression: defs
---
[
  {
    "description": "Run a shell command inside the container and observe its output. Use this for all work, including cowboy CLIs like `cowboy patch`.",
    "name": "shell",
    "parameters": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "description": "Arguments for the `shell` tool.",
      "properties": {
        "command": {
          "description": "The shell command to run inside the container (executed with `sh -lc`).",
          "type": "string"
        },
        "cwd": {
          "default": null,
          "description": "Optional working directory (defaults to the container workdir).",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "command"
      ],
      "title": "ShellArgs",
      "type": "object"
    }
  },
  {
    "description": "Finish the task. Provide a summary of what changed, what was validated, and any remaining risks or follow-up work.",
    "name": "final",
    "parameters": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "description": "Arguments for the `final` tool.",
      "properties": {
        "message": {
          "description": "A summary of what changed, what was validated, and any follow-ups.",
          "type": "string"
        }
      },
      "required": [
        "message"
      ],
      "title": "FinalArgs",
      "type": "object"
    }
  },
  {
    "description": "Ask the user a question when you are genuinely blocked and cannot proceed without their input.",
    "name": "ask_user",
    "parameters": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "description": "Arguments for the `ask_user` tool.",
      "properties": {
        "question": {
          "description": "A question for the user when the agent is genuinely blocked.",
          "type": "string"
        }
      },
      "required": [
        "question"
      ],
      "title": "AskUserArgs",
      "type": "object"
    }
  }
]
