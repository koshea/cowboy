# Rust build artifacts
/target

# Secrets and local env
.env

# cowboy session logs (per-project, not source)
.cowboy/sessions/

# insta pending snapshots
**/*.snap.new

# mdBook build output (the docs site is built from docs/src/)
/docs/book

# OS / editor cruft
.DS_Store

# local agent/tooling state (not project source)
.claude/

# cowboy
.cowboy/ranches/*/events.jsonl
.cowboy/ranches/*/workstreams/
